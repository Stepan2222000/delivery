# ─── Auth ─────────────────────────────────────────────────────────────────────
# Plain-text passwords compared via constant-time hmac.compare_digest.
ADMIN_LOGIN=stepan
ADMIN_PASSWORD=ChangeMe
FORWARDER_LOGIN=kg_team
FORWARDER_PASSWORD=ChangeMe
SESSION_TTL_DAYS=30
COOKIE_SECURE=false
COOKIE_NAME=delivery_session

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=8002
WEB_ORIGIN=http://localhost:3000

# ─── Sync worker ──────────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=5
