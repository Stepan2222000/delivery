# ─── Postgres (delivery DB) ───────────────────────────────────────────────────
DELIVERY_PG_DSN=postgresql://admin:Password123@2.26.53.128:5408/delivery

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=2.26.53.128:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=Password123
MINIO_SECURE=false
MINIO_BUCKET_PHOTOS=parts-photos
MINIO_BUCKET_WAYBILLS=delivery-photos
MINIO_PHOTO_PREFIX=delivery/parcels
